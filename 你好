#!name=HelloTalk去开屏广告
#!desc=仅屏蔽HelloTalk启动页广告（更稳定）
#!author=ChatGPT

[Rewrite]
# 直接拦截开屏广告接口（常见路径特征）
^https:\/\/.*hellotalk\.com\/.*(splash|launch|startup|boot|ad).* url reject

[Script]
# 如果广告是接口返回数据（而不是单独请求）
http-response ^https:\/\/.*hellotalk\.com\/.*(config|init|startup).* script-path=https://raw.githubusercontent.com/blackmatrix7/ios_rule_script/master/script/rewrite/empty.js, requires-body=true

[MITM]
hostname = *.hellotalk.com
